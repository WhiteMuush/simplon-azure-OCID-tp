# Configuration de l'infra Azure, lue par azure-setup.sh et azure-teardown.sh.
# Copier ce fichier en .env et adapter les valeurs. Le .env n'est PAS versionne.
# Ce ne sont que des identifiants (pas de secret) : l'auth Azure se fait en OIDC.
SUBSCRIPTION=00000000-0000-0000-0000-000000000000   # ID de l'abonnement Azure
RG=mon-resource-group                                 # resource group cible
LOC=francecentral                                     # region Azure
ACR=monacr                                            # nom du registre (unique global)
ENVNAME=cae-mon-staging                               # Container Apps environment
APP=ca-mon-app-staging                                # Container App
MI=gitlab-ci                                           # user-assigned managed identity
GITLAB_PROJECT=Groupe/mon-projet                      # chemin du projet GitLab (OIDC)
